#!/usr/bin/env python3
"""cc-fork — spawn parallel Claude Code subagents that inherit current session context.

Each fork is created by snapshotting the parent session's JSONL, copying it to a
new v4 UUID file in the same project dir, and launching `claude --resume <uuid> -p`
against it. Forks inherit the full parent conversation. Cleanup deletes the forked
JSONLs (and any sidecar metadata files) on exit by default.

Usage:
    cc-fork "task1" "task2" "task3"
    cc-fork --parent <uuid> --model opus "task1" "task2"
    cc-fork --keep --output-dir /tmp/out "task1" "task2"
"""
from __future__ import annotations

import argparse
import fcntl
import json
import os
import re
import shutil
import signal
import subprocess
import sys
import threading
import time
import uuid
from pathlib import Path

V4_UUID_RE = re.compile(
    r"^[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}\.jsonl$",
    re.IGNORECASE,
)


def encode_project_path(cwd: Path) -> str:
    """Claude Code encodes project paths by replacing / and . with -."""
    return re.sub(r"[/.]", "-", str(cwd.resolve()))


def find_project_dir(cwd: Path) -> Path:
    """Locate ~/.claude/projects/<encoded-cwd>/"""
    encoded = encode_project_path(cwd)
    project_dir = Path.home() / ".claude" / "projects" / encoded
    if not project_dir.is_dir():
        sys.exit(
            f"cc-fork: no Claude session directory for {cwd} "
            f"(expected {project_dir}). Start a session in this dir first."
        )
    return project_dir


def find_parent_jsonl(project_dir: Path, explicit: str | None) -> Path:
    """Return the parent session JSONL. Explicit UUID wins; else pick largest by size."""
    if explicit:
        p = project_dir / f"{explicit}.jsonl"
        if not p.is_file():
            sys.exit(f"cc-fork: --parent {explicit} not found at {p}")
        return p

    candidates = [
        f for f in project_dir.glob("*.jsonl")
        if V4_UUID_RE.match(f.name) and f.stat().st_size > 500
    ]
    if not candidates:
        sys.exit(
            f"cc-fork: no substantive session JSONL found in {project_dir}. "
            f"Pass --parent <uuid> or start a session first."
        )
    # Largest file is almost always the real conversation (sidecars are tiny).
    return max(candidates, key=lambda f: f.stat().st_size)


def new_uuid() -> str:
    return str(uuid.uuid4())


def acquire_project_lock(project_dir: Path, log):
    """Exclusive flock on a per-project lock file. Serializes cc-fork runs in
    the same project dir so their mtime-based cleanups can't eat each other's
    fork/sidecar files. Returned file handle must stay open for the lock to hold.
    """
    lock_path = project_dir / ".cc-fork.lock"
    lock_fh = open(lock_path, "w")
    try:
        fcntl.flock(lock_fh.fileno(), fcntl.LOCK_EX | fcntl.LOCK_NB)
    except BlockingIOError:
        log(f"another cc-fork is running in {project_dir} — waiting for lock…")
        fcntl.flock(lock_fh.fileno(), fcntl.LOCK_EX)
    return lock_fh


def run_fork(
    uuid_: str,
    task: str,
    model: str | None,
    metrics: bool,
    index: int,
    outputs: list[str | None],
    errors: list[str | None],
    usages: list[dict | None],
) -> None:
    """Run one `claude --resume` invocation. Stores output in outputs[index]."""
    cmd = ["claude", "--resume", uuid_, "-p"]
    if model:
        cmd += ["--model", model]
    if metrics:
        cmd += ["--output-format", "json"]
    cmd.append(task)
    env = {**os.environ, "CLAUDECODE": "", "CLAUDE_CODE_ENTRYPOINT": ""}
    try:
        result = subprocess.run(
            cmd,
            env=env,
            capture_output=True,
            text=True,
            timeout=600,
        )
        if metrics and result.returncode == 0:
            try:
                parsed = json.loads(result.stdout)
                outputs[index] = parsed.get("result", "")
                usages[index] = {
                    "usage": parsed.get("usage", {}),
                    "cost_usd": parsed.get("total_cost_usd") or parsed.get("cost_usd"),
                    "duration_ms": parsed.get("duration_ms"),
                }
            except json.JSONDecodeError:
                outputs[index] = result.stdout
                errors[index] = "metrics: could not parse JSON output"
        else:
            outputs[index] = result.stdout
        if result.returncode != 0:
            errors[index] = f"exit {result.returncode}: {result.stderr.strip()}"
    except subprocess.TimeoutExpired:
        errors[index] = "timed out after 600s"
    except Exception as e:
        errors[index] = f"{type(e).__name__}: {e}"


def main() -> int:
    ap = argparse.ArgumentParser(
        description="Spawn parallel Claude subagents that inherit the current session's context."
    )
    ap.add_argument("tasks", nargs="+", help="One task per fork (positional args).")
    ap.add_argument(
        "--parent", metavar="UUID",
        help="Parent session UUID. Default: largest JSONL in this project's session dir.",
    )
    ap.add_argument(
        "--model", default=None,
        help="Model for forks (haiku/sonnet/opus). Default: Claude Code default.",
    )
    ap.add_argument(
        "--stagger", type=float, default=1.0,
        help="Seconds between fork launches. Default: 1.0 (required to avoid session-index race).",
    )
    ap.add_argument(
        "--output-dir", metavar="DIR",
        help="Write each fork's output to <DIR>/fork-NN.out instead of stdout.",
    )
    ap.add_argument(
        "--keep", action="store_true",
        help="Don't delete forked JSONLs on exit. Useful for debugging.",
    )
    ap.add_argument(
        "--metrics", action="store_true",
        help="Run forks with --output-format json and print a per-fork + aggregate token/cost report.",
    )
    ap.add_argument(
        "--quiet", action="store_true",
        help="Suppress progress messages to stderr.",
    )
    args = ap.parse_args()

    def log(msg: str) -> None:
        if not args.quiet:
            print(f"cc-fork: {msg}", file=sys.stderr)

    cwd = Path.cwd()
    project_dir = find_project_dir(cwd)
    parent = find_parent_jsonl(project_dir, args.parent)
    log(f"parent session: {parent.name} ({parent.stat().st_size // 1024}K)")

    # Hold an exclusive lock for the duration of this run so mtime-based
    # cleanup can't delete a concurrent cc-fork's files.
    lock_fh = acquire_project_lock(project_dir, log)

    start_time = time.time()
    fork_uuids = [new_uuid() for _ in args.tasks]
    for u in fork_uuids:
        shutil.copy2(parent, project_dir / f"{u}.jsonl")
    log(f"created {len(fork_uuids)} fork(s)")

    # Cleanup: delete every JSONL newer than start_time (forks + sidecars),
    # except the parent. mtime-based beats name-diff because sidecars can be
    # written asynchronously and race a set-based post-run scan.
    def cleanup() -> None:
        if args.keep:
            log(f"--keep: leaving forks in {project_dir}")
            return
        # Two-pass with a short delay to catch late-arriving sidecars.
        for _ in range(2):
            for f in project_dir.glob("*.jsonl"):
                if f.name == parent.name:
                    continue
                try:
                    if f.stat().st_mtime >= start_time:
                        f.unlink()
                except OSError:
                    pass
            time.sleep(0.3)

    def sig_handler(signum: int, _frame) -> None:
        cleanup()
        sys.exit(128 + signum)

    signal.signal(signal.SIGINT, sig_handler)
    signal.signal(signal.SIGTERM, sig_handler)

    outputs: list[str | None] = [None] * len(args.tasks)
    errors: list[str | None] = [None] * len(args.tasks)
    usages: list[dict | None] = [None] * len(args.tasks)
    threads: list[threading.Thread] = []

    try:
        for i, (u, task) in enumerate(zip(fork_uuids, args.tasks)):
            t = threading.Thread(
                target=run_fork,
                args=(u, task, args.model, args.metrics, i, outputs, errors, usages),
                daemon=True,
            )
            t.start()
            threads.append(t)
            log(f"launched fork {i + 1}/{len(args.tasks)} ({u[:8]})")
            if i < len(args.tasks) - 1:
                time.sleep(args.stagger)

        for t in threads:
            t.join()
    finally:
        cleanup()
        lock_fh.close()  # release flock

    if args.output_dir:
        out_dir = Path(args.output_dir)
        out_dir.mkdir(parents=True, exist_ok=True)
        for i, (task, output, err) in enumerate(zip(args.tasks, outputs, errors)):
            path = out_dir / f"fork-{i + 1:02d}.out"
            content = output or ""
            if err:
                content = f"[ERROR] {err}\n{content}"
            path.write_text(content)
        log(f"wrote {len(args.tasks)} output file(s) to {out_dir}")
    else:
        for i, (task, output, err) in enumerate(zip(args.tasks, outputs, errors)):
            print(f"\n=== fork {i + 1}: {task[:60]}{'…' if len(task) > 60 else ''} ===")
            if err:
                print(f"[ERROR] {err}", file=sys.stderr)
            print((output or "").rstrip())

    if args.metrics:
        print_metrics(args.tasks, usages, errors)

    return 1 if any(errors) else 0


def print_metrics(
    tasks: list[str],
    usages: list[dict | None],
    errors: list[str | None],
) -> None:
    """Render a per-fork and aggregate usage table to stderr."""
    def g(d: dict, *path) -> int:
        cur = d
        for k in path:
            if not isinstance(cur, dict):
                return 0
            cur = cur.get(k, 0)
        return cur or 0

    print("\n=== cc-fork metrics ===", file=sys.stderr)
    print(
        f"{'fork':<5} {'input':>8} {'output':>8} {'cache_w':>9} {'cache_r':>10} {'cost':>9} {'dur_ms':>8}",
        file=sys.stderr,
    )
    totals = {"in": 0, "out": 0, "cw": 0, "cr": 0, "cost": 0.0, "dur": 0}
    for i, (task, u, err) in enumerate(zip(tasks, usages, errors)):
        if not u:
            note = err or "no metrics"
            print(f"{i + 1:<5} {'— ' + note:<60}", file=sys.stderr)
            continue
        usage = u.get("usage", {})
        in_t = g(usage, "input_tokens")
        out_t = g(usage, "output_tokens")
        cw = g(usage, "cache_creation_input_tokens")
        cr = g(usage, "cache_read_input_tokens")
        cost = u.get("cost_usd") or 0
        dur = u.get("duration_ms") or 0
        totals["in"] += in_t; totals["out"] += out_t
        totals["cw"] += cw; totals["cr"] += cr
        totals["cost"] += cost; totals["dur"] += dur
        print(
            f"{i + 1:<5} {in_t:>8,} {out_t:>8,} {cw:>9,} {cr:>10,} {'$' + format(cost, '.4f'):>9} {dur:>8,}",
            file=sys.stderr,
        )
    print(
        f"{'TOT':<5} {totals['in']:>8,} {totals['out']:>8,} {totals['cw']:>9,} {totals['cr']:>10,} "
        f"{'$' + format(totals['cost'], '.4f'):>9} {totals['dur']:>8,}",
        file=sys.stderr,
    )
    saved = totals["cr"]
    if saved:
        print(
            f"\ncache_read saved ~{saved:,} tokens vs re-sending "
            f"(~{saved * 0.9 / 1000:.1f}K tokens @ 0.1× input rate).",
            file=sys.stderr,
        )


if __name__ == "__main__":
    sys.exit(main())
